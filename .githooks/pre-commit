#!/bin/sh
# Pre-commit hook to format and analyze Dart/Flutter code

echo "Running dart format..."
dart format --output=none --set-exit-if-changed .
FORMAT_EXIT_CODE=$?

if [ $FORMAT_EXIT_CODE -ne 0 ]; then
  echo "\n[ERROR] Formatting failed. Please format your files before committing."
  echo "You can run 'dart format .' to automatically format the code."
  exit 1
fi

echo "\nRunning flutter analyze..."
flutter analyze
ANALYZE_EXIT_CODE=$?

if [ $ANALYZE_EXIT_CODE -ne 0 ]; then
  echo "\n[ERROR] Static analysis found issues. Please fix the lint errors before committing."
  exit 1
fi

echo "\nPre-commit checks passed successfully!"
exit 0
